<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import com.example.oop_20252.view.TreePanel?>
<?import com.example.oop_20252.view.CodePanel?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.oop_20252.controller.VisualizationController"
            stylesheets="@app.css"
            styleClass="vis-root">

    <top>
        <VBox styleClass="top-container">
            <padding><Insets top="15" right="20" bottom="15" left="20"/></padding>
            <HBox styleClass="vis-header" spacing="20.0" alignment="CENTER_LEFT">
                <Button fx:id="btnBack" text="← Main menu" onAction="#onBack" styleClass="button-back"/>
                <Label fx:id="titleLabel" text="Visualization" styleClass="vis-title"/>
                <Region HBox.hgrow="ALWAYS" />
                <ComboBox fx:id="binarySubtypeChoice" visible="false" managed="false" prefWidth="120" styleClass="combo-box"/>
            </HBox>
            <Region prefHeight="15"/>
            <HBox styleClass="vis-toolbar" spacing="16.0" alignment="CENTER_LEFT">
                <Label text="Op:" styleClass="form-label"/>
                <ComboBox fx:id="operationChoice" prefWidth="130"/>

                <Label text="Val:" styleClass="form-label"/>
                <TextField fx:id="valueField" promptText="value" prefWidth="80"/>

                <Label text="Parent:" styleClass="form-label"/>
                <TextField fx:id="parentValueField" promptText="parent (opt)" prefWidth="100"/>

                <Label text="New val:" styleClass="form-label"/>
                <TextField fx:id="newValueField" promptText="update" prefWidth="80"/>

                <Label text="Traversal:" styleClass="form-label"/>
                <ComboBox fx:id="traverseChoice" prefWidth="90"/>

                <Label text="RB Del Mode:" styleClass="form-label"/>
                <ComboBox fx:id="rbDeleteModeChoice" prefWidth="120"/>

                <CheckBox fx:id="showNilLeavesCheck" text="Show NILs" styleClass="form-label"/>

                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="btnRun" text="▶ Execute" onAction="#onRun" styleClass="button-run"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <SplitPane orientation="HORIZONTAL" dividerPositions="0.72" styleClass="vis-split" style="-fx-background-color: transparent; -fx-padding: 0 20 20 20;">
            <items>
                <VBox styleClass="panel-card" alignment="CENTER" style="-fx-background-color: rgba(13, 17, 23, 0.4); -fx-border-color: rgba(48, 54, 61, 0.4);">
                    <TreePanel fx:id="treePanel" VBox.vgrow="ALWAYS" />
                </VBox>

                <VBox styleClass="vis-right-column" spacing="16.0" style="-fx-padding: 0 0 0 10;">
                    <VBox styleClass="panel-card" spacing="10.0">
                        <Label text="Operation Status" styleClass="panel-card-title"/>
                        <Label fx:id="statusLabel" text="Ready." styleClass="status-label" wrapText="true"/>
                    </VBox>

                    <VBox styleClass="panel-card" spacing="10.0">
                        <Label text="Traversal Path" styleClass="panel-card-title"/>
                        <Label fx:id="traversalOrderLabel" text="(empty)" wrapText="true" styleClass="traversal-order"/>
                        <Label text="Cyan = Current node · Green = Visited" styleClass="legend-label"/>
                    </VBox>

                    <VBox styleClass="panel-card" spacing="8.0" VBox.vgrow="ALWAYS">
                        <Label text="Algorithm Pseudocode" styleClass="panel-card-title"/>
                        <CodePanel fx:id="codePanel" VBox.vgrow="ALWAYS"/>
                    </VBox>
                </VBox>
            </items>
        </SplitPane>
    </center>

    <bottom>
        <HBox styleClass="playback-bar" spacing="16.0" alignment="CENTER_LEFT">
            <Button fx:id="btnStepBack" text="Step Back" onAction="#onStepBack" styleClass="button-playback"/>
            <Button fx:id="btnPause" text="Pause" onAction="#onPause" styleClass="button-playback"/>
            <Button fx:id="btnContinue" text="Play" onAction="#onContinue" styleClass="button-playback button-primary-outline"/>
            <Button fx:id="btnStepForward" text="Step Forward" onAction="#onStepForward" styleClass="button-playback"/>

            <Separator orientation="VERTICAL" style="-fx-opacity: 0.1;"/>

            <Button fx:id="btnUndo" text="Undo Action" onAction="#onUndo" styleClass="button-playback"/>
            <Button fx:id="btnRedo" text="Redo Action" onAction="#onRedo" styleClass="button-playback"/>

            <Separator orientation="VERTICAL" style="-fx-opacity: 0.1;"/>

            <!-- <Button fx:id="btnCopyJson" text="Export Debug" onAction="#onCopyJson" styleClass="button-back"/> -->

            <Region HBox.hgrow="ALWAYS"/>
            <VBox spacing="4.0" alignment="CENTER_RIGHT">
                <Label text="Playback Speed" styleClass="panel-card-title" style="-fx-font-size: 10px;"/>
                <Slider fx:id="speedSlider" min="100" max="1500" value="500" showTickMarks="false" prefWidth="150" />
            </VBox>
            <ProgressBar fx:id="progressBar" prefWidth="240" progress="0.0" />
        </HBox>
    </bottom>
</BorderPane>
