<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.oop_20252.controller.MainMenuController"
      stylesheets="@app.css"
      styleClass="main-menu-root"
      alignment="CENTER"
      spacing="30.0">
    <VBox alignment="CENTER" spacing="10">
        <Label text="Tree Visualization" styleClass="main-menu-title"/>
        <Label text="N-ary · Binary Search Structure · Red-Black Tree"
               styleClass="main-menu-subtitle"/>
    </VBox>

    <VBox styleClass="main-menu-card" spacing="25.0" alignment="CENTER" maxWidth="750">
        <padding><Insets top="30" right="40" bottom="30" left="40"/></padding>
        <Label text="Select Data Structure" styleClass="panel-card-title" style="-fx-font-size: 18px;"/>
        <HBox styleClass="main-menu-tree-row" spacing="25.0" alignment="CENTER">
            <Button fx:id="btnBST" text="BST" onAction="#onSelectBST" styleClass="button-tree-choice" prefWidth="150" prefHeight="60"/>
            <Button fx:id="btnAVL" text="AVL Tree" onAction="#onSelectAVL" styleClass="button-tree-choice" prefWidth="150" prefHeight="60"/>
            <Button fx:id="btnRB" text="Red-Black Tree" onAction="#onSelectRedBlack" styleClass="button-tree-choice" prefWidth="150" prefHeight="60"/>
            <Button fx:id="btnGeneric" text="N-ary Tree" onAction="#onSelectGeneric" styleClass="button-tree-choice" prefWidth="150" prefHeight="60"/>
        </HBox>
        <Region prefHeight="10"/>
        <HBox alignment="CENTER" spacing="15.0">
            <Button text="Help / How to use" onAction="#onHelpHowToUse" styleClass="button-playback"/>
            <Button fx:id="btnQuit" text="Quit App" onAction="#onQuit" styleClass="button-quit"/>
        </HBox>
    </VBox>
</VBox>
